NODE_ENV=development
PORT=3333
WEB_ORIGIN=http://localhost:3000
JWT_SECRET=troque-esta-chave-por-uma-chave-grande
JWT_EXPIRES_IN=7d
DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=atlas_das_cinzas
DB_USER=atlas
DB_PASSWORD=atlas
# Use DB_SYNCHRONIZE=true apenas em desenvolvimento local para prototipar entidades.
# Em produção deixe DB_SYNCHRONIZE=false e aplique o schema com "npm run migration:run".
DB_SYNCHRONIZE=false
DB_RUN_MIGRATIONS=false
DB_LOGGING=false
# Ative para Postgres gerenciado (Neon, Supabase, etc.) que exige TLS.
DB_SSL=false
REDIS_URL=redis://localhost:6379

# Desative em produção (deixe rodar sob demanda em uma janela de manutenção)
# se a base já tiver muitas campanhas/hexágonos, para não atrasar o boot.
HEX_MAINTENANCE_ON_BOOT=true

SRD_API_BASE_URL=https://www.dnd5eapi.co
SRD_SYNC_ON_START=true
